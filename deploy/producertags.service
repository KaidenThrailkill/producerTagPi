[Unit]
Description=ProducerTags GitHub webhook audio service
After=network-online.target sound.target
Wants=network-online.target

[Service]
Type=simple
User=pi
WorkingDirectory=/home/pi/producerTagPi
EnvironmentFile=/home/pi/producerTagPi/.env
ExecStart=/home/pi/producerTagPi/.venv/bin/uvicorn app:app --host 127.0.0.1 --port 8000
Restart=on-failure
RestartSec=3

[Install]
WantedBy=multi-user.target
